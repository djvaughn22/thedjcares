# TheDJCares environment.
# Copy to .env.local for local work; set real values in Vercel → Project
# Settings → Environment Variables. NEVER commit real values.

# ── Daily Social Engine → Instagram (see docs/DAILY-INSTAGRAM.md) ─────────
# Emergency pause switch: cron publishing runs only when exactly "true".
INSTAGRAM_AUTOPUBLISH_ENABLED=false
# The Instagram professional account's numeric ID.
INSTAGRAM_ACCOUNT_ID=
# Long-lived access token with content-publishing permission.
META_ACCESS_TOKEN=
# App credentials (token generation/refresh).
META_APP_ID=
META_APP_SECRET=
# Graph API base. Default: https://graph.facebook.com/v23.0
META_GRAPH_API_BASE=
# Vercel Cron sends "Authorization: Bearer $CRON_SECRET" when set.
CRON_SECRET=
# Optional America/Chicago hour gate (0-23) — only for hourly cron schedules.
INSTAGRAM_PUBLISH_HOUR=
# Key for /admin/social?key=... and manual publish calls.
SOCIAL_ADMIN_KEY=
# Public origin override for the image URL Meta fetches (defaults to
# https://thedjcares.com).
SITE_BASE_URL=
# Optional comma-separated hashtag override.
SOCIAL_HASHTAGS=
